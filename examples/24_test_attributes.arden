// Test 24: Function Attributes/Annotations & Assert Functions
// Tests: @Test, @Ignore, @Before, @After, @BeforeAll, @AfterAll
// Tests: assert, assert_eq, assert_ne, assert_true, assert_false

import std.io.*;
import std.string.*;

@BeforeAll
function initTests(): None {
    println("=== Initializing Test Suite ===");
    return None;
}

@Before
function setup(): None {
    println("  [Setup]");
    return None;
}

@After
function teardown(): None {
    println("  [Teardown]");
    return None;
}

@Test
function testAddition(): None {
    result: Integer = 2 + 2;
    assert_eq(result, 4);
    return None;
}

@Test
function testSubtraction(): None {
    result: Integer = 10 - 3;
    assert_eq(result, 7);
    return None;
}

@Test
function testMultiplication(): None {
    result: Integer = 6 * 7;
    assert_eq(result, 42);
    return None;
}

@Test
function testDivision(): None {
    result: Integer = 20 / 4;
    assert_eq(result, 5);
    return None;
}

@Test
function testBooleanLogic(): None {
    assert_true(true);
    assert_false(false);
    return None;
}

@Test
function testStringEquality(): None {
    // Note: String comparison uses ownership, so we compare directly
    assert_eq("Hello", "Hello");
    assert_ne("Hello", "World");
    return None;
}

@Test
function testIntegerComparisons(): None {
    assert_eq(5, 5);
    assert_ne(5, 10);
    return None;
}

@Test
@Ignore("This test is intentionally ignored for demo")
function testIgnored(): None {
    // This test should not run
    fail("This should not be called!");
    return None;
}

@Test
@Ignore
function testIgnoredNoReason(): None {
    // This test should also not run
    fail("This should not be called!");
    return None;
}

@Test
function testAssertCondition(): None {
    x: Integer = 10;
    assert(x > 5);
    assert(x < 20);
    return None;
}

@AfterAll
function cleanupTests(): None {
    println("=== Test Suite Complete ===");
    return None;
}

// Normal function without attributes - not a test
function helperFunction(): Integer {
    return 42;
}

// Main function for direct execution (runs tests manually)
function main(): None {
    println("This file contains tests. Run with: arden test --path 24_test_attributes.arden");
    println("Or run tests directly:");
    println("");
    
    initTests();
    setup();
    testAddition();
    teardown();
    println("testAddition: PASS");
    
    setup();
    testSubtraction();
    teardown();
    println("testSubtraction: PASS");
    
    setup();
    testMultiplication();
    teardown();
    println("testMultiplication: PASS");
    
    cleanupTests();
    
    return None;
}
