// Test 20: System Functions
// Tests: System.os, System.cwd, exit

import std.io.*;
import std.system.*;

function main(): None {
    println("=== System Tests ===");

    // Get OS info
    os: String = System.os();
    println("Operating System: " + os);

    // Get current working directory
    dir: String = System.cwd();
    println("Current Directory: " + dir);

    println("");
    println("System tests complete!");

    return None;
}
